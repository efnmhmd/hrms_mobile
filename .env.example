# API base URL — must include /api at the end (matches web frontend convention).
#
# Web dev          → http://localhost:5006/api
# Android emulator → http://10.0.2.2:5006/api   (special alias for host machine)
# iOS simulator    → http://localhost:5006/api
# Real device      → http://<your-LAN-IP>:5006/api  (phone must be on same Wi-Fi)
# Production       → https://hrms.yourdomain.com/api
VITE_API_BASE_URL=http://localhost:5006/api

# ─────────────────────────────────────────────────────────────────
# Backend CORS reminder (no env var here — change in backend .env):
#
# Production backends MUST add the Capacitor WebView origins to CORS_ORIGIN:
#   CORS_ORIGIN=https://hrms.yourdomain.com,capacitor://localhost,http://localhost
#
#   - capacitor://localhost  → iOS WebView origin
#   - http://localhost       → Android WebView origin (with default config)
#
# Dev backends allow all origins, so no action needed for local development.
# ─────────────────────────────────────────────────────────────────
